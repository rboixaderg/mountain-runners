---
import "../../styles/global.css";
import { renderRestrictedMarkdown } from "../../lib/content/markdown";
import {
  getPublicResourcePath,
  type PublishedVariant,
} from "../../lib/content/publication";
import { getPublicationCatalog } from "../../lib/content/repository";
import { getAlternateVariants, getVariantPath } from "../../lib/content/routes";

type PageVariant = Extract<PublishedVariant, { kind: "page" }>;

export async function getStaticPaths() {
  const catalog = await getPublicationCatalog();
  return catalog.variants
    .filter((variant): variant is PageVariant => variant.kind === "page")
    .map((variant) => ({
      params: { locale: variant.locale, slug: variant.slug },
      props: {
        variant,
        alternates: getAlternateVariants(catalog, variant),
      },
    }));
}

const { variant, alternates } = Astro.props as {
  variant: PageVariant;
  alternates: PublishedVariant[];
};
const { entry, locale } = variant;
const catalog = await getPublicationCatalog();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={entry.seoDescription[locale]} />
    <link rel="canonical" href={getVariantPath(variant)} />
    {
      alternates.map((alternate) => (
        <link
          rel="alternate"
          hreflang={alternate.locale}
          href={getVariantPath(alternate)}
        />
      ))
    }
    <title>{entry.seoTitle[locale]}</title>
  </head>
  <body>
    <main class="mx-auto max-w-3xl px-6 py-20">
      <h1 class="text-5xl font-black tracking-tight">{entry.title[locale]}</h1>
      <p class="mt-6 text-lg">{entry.summary[locale]}</p>
      {
        entry.blocks.map((block) => {
          if (block.type === "rich-text") {
            return (
              <section
                class="mt-8"
                set:html={renderRestrictedMarkdown(block.body[locale]!)}
              />
            );
          }
          if (block.type === "image") {
            return <p class="mt-8">{block.image.alt[locale]}</p>;
          }
          if (block.type === "gallery") {
            return (
              <ul class="mt-8">
                {block.images.map((image) => (
                  <li>{image.alt[locale]}</li>
                ))}
              </ul>
            );
          }
          if (block.type === "links") {
            return (
              <ul class="mt-8">
                {block.links.map((link) => (
                  <li>
                    <a href={link.url[locale]}>{link.label[locale]}</a>
                  </li>
                ))}
              </ul>
            );
          }
          return (
            <ul class="mt-8">
              {block.documentIds.map((id) => {
                const document = catalog.documents.get(id)!;
                const href =
                  document.resource.kind === "local"
                    ? getPublicResourcePath(document.resource.path)
                    : document.resource.url;
                return (
                  <li>
                    <a href={href}>{document.title[locale]}</a>
                  </li>
                );
              })}
            </ul>
          );
        })
      }
    </main>
  </body>
</html>
