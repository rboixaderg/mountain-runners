---
import "../../styles/global.css";
import { locales } from "../../../i18n.config.mjs";
import * as m from "../../paraglide/messages.js";
import { assertIsLocale } from "../../paraglide/runtime.js";

const locale = assertIsLocale(Astro.currentLocale);
const canonicalUrl = new URL(`/${locale}/`, Astro.site);

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={m.intro()} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{m.site_title()}</title>
  </head>
  <body>
    <main class="mx-auto max-w-3xl px-6 py-20">
      <p class="text-club-red mb-3 font-bold tracking-widest uppercase">
        {m.site_title()}
      </p>
      <h1 class="text-5xl font-black tracking-tight">
        {m.under_construction()}
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed">
        {m.intro()}
      </p>
    </main>
  </body>
</html>
