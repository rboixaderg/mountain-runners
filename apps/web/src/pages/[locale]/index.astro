---
import { locales } from "../../../i18n.config.mjs";
import * as m from "../../paraglide/messages.js";
import { assertIsLocale } from "../../paraglide/runtime.js";
import PublicLayout from "../../layouts/PublicLayout.astro";

const locale = assertIsLocale(Astro.currentLocale);
const canonicalUrl = new URL(`/${locale}/`, Astro.site);

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}
---

<PublicLayout
  canonical={canonicalUrl.toString()}
  description={m.intro({}, { locale })}
  locale={locale}
  title={m.site_title()}
>
  <section
    class="page-frame max-w-[var(--reading-width)] py-[clamp(var(--space-12),10vw,7rem)]"
  >
    <p
      class="m-0 font-[family-name:var(--font-display)] text-lg tracking-[0.06em] uppercase"
    >
      {m.site_title()}
    </p>
    <h1
      class="my-3 mb-6 max-w-[15ch] font-[family-name:var(--font-display)] text-[clamp(2.8rem,9vw,5.5rem)] leading-[0.95] tracking-[0.015em] uppercase"
    >
      {m.under_construction({}, { locale })}
    </h1>
    <p class="text-[clamp(1.1rem,2vw,1.3rem)]">{m.intro({}, { locale })}</p>
  </section>
</PublicLayout>
