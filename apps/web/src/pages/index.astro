---
import "../styles/global.css";
---

<!doctype html>
<html lang="ca">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Web de Mountain Runners del Berguedà" />
    <title>Mountain Runners</title>
  </head>
  <body>
    <main class="mx-auto max-w-3xl px-6 py-20">
      <p class="text-club-red mb-3 font-bold tracking-widest uppercase">
        Mountain Runners
      </p>
      <h1 class="text-5xl font-black tracking-tight">
        Base web en construcció
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed">
        Estem preparant la nova web de l'associació amb una base ràpida,
        accessible i mantenible.
      </p>
    </main>
  </body>
</html>
