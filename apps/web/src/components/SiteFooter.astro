---
import * as m from "../paraglide/messages.js";
import type { Locale } from "../lib/content/primitives";
import { getDomainPath } from "../lib/content/routes";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<footer class="border-t border-[var(--color-line)]">
  <div
    class="page-frame flex min-h-18 flex-col items-start justify-between gap-3 py-4 sm:flex-row sm:items-center sm:py-0"
  >
    <p
      class="m-0 font-[family-name:var(--font-display)] text-lg tracking-[0.06em] uppercase"
    >
      {m.site_title()}
    </p>
    <nav
      class="flex items-center gap-4 text-sm"
      aria-label={m.footer_navigation({}, { locale })}
    >
      <a class="font-bold" href={`/${locale}/`}
        >{m.navigation_home({}, { locale })}</a
      >
      <a class="font-bold" href={getDomainPath("event", locale)}
        >{m.navigation_events({}, { locale })}</a
      >
    </nav>
  </div>
</footer>
