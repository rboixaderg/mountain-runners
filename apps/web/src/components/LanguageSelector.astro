---
import * as m from "../paraglide/messages.js";
import type { Locale } from "../lib/content/primitives";

type LocalizedAlternative = { locale: Locale; href: string };

interface Props {
  localizedAlternatives: LocalizedAlternative[];
  locale: Locale;
}

const { localizedAlternatives, locale } = Astro.props;
const languageNames: Record<Locale, string> = {
  ca: m.language_ca({}, { locale }),
  es: m.language_es({}, { locale }),
  en: m.language_en({}, { locale }),
};
---

{
  localizedAlternatives.length > 1 && (
    <nav aria-label={m.language_selector({}, { locale })}>
      <ul class="flex list-none items-center gap-4 p-0 text-sm">
        {localizedAlternatives.map((alternative) => (
          <li>
            {alternative.locale === locale ? (
              <span
                class="font-bold text-[var(--color-muted)]"
                aria-current="page"
              >
                {languageNames[alternative.locale]}
              </span>
            ) : (
              <a
                class="font-bold"
                href={alternative.href}
                hreflang={alternative.locale}
              >
                {languageNames[alternative.locale]}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>
  )
}
