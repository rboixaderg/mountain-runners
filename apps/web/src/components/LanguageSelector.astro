---
import * as m from "../paraglide/messages.js";
import type { Locale } from "../lib/content/primitives";

type Alternate = { locale: Locale; href: string };

interface Props {
  alternates: Alternate[];
  locale: Locale;
}

const { alternates, locale } = Astro.props;
const languageNames: Record<Locale, string> = {
  ca: m.language_ca({}, { locale }),
  es: m.language_es({}, { locale }),
  en: m.language_en({}, { locale }),
};
---

{
  alternates.length > 1 && (
    <nav aria-label={m.language_selector({}, { locale })}>
      <ul class="flex list-none items-center gap-4 p-0 text-sm">
        {alternates.map((alternate) => (
          <li>
            {alternate.locale === locale ? (
              <span
                class="font-bold text-[var(--color-muted)]"
                aria-current="page"
              >
                {languageNames[alternate.locale]}
              </span>
            ) : (
              <a
                class="font-bold"
                href={alternate.href}
                hreflang={alternate.locale}
                lang={alternate.locale}
              >
                {languageNames[alternate.locale]}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>
  )
}
