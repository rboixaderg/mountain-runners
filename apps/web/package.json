{
  "name": "@mountain-runners/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm paraglide:generate && astro build && node scripts/verify-i18n-output.mjs",
    "dev": "astro dev",
    "paraglide:generate": "node scripts/generate-paraglide.mjs",
    "paraglide:verify": "node scripts/verify-paraglide-generation.mjs",
    "test": "pnpm paraglide:generate && pnpm paraglide:verify && vitest run",
    "typecheck": "pnpm paraglide:generate && astro check"
  },
  "dependencies": {
    "@inlang/paraglide-js": "2.22.0",
    "@inlang/plugin-message-format": "4.4.0",
    "@tailwindcss/vite": "4.3.2",
    "astro": "7.0.9",
    "tailwindcss": "4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
