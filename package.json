{
  "name": "mountain-runners",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.11.0",
    "pnpm": "10.33.0"
  },
  "scripts": {
    "build": "pnpm --filter @mountain-runners/web build",
    "dev": "pnpm --filter @mountain-runners/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm --filter @mountain-runners/web paraglide:generate && eslint .",
    "prepare": "husky",
    "test": "pnpm --filter @mountain-runners/web test",
    "typecheck": "pnpm --filter @mountain-runners/web typecheck",
    "validate": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "lint-staged": {
    "*.{astro,css,js,mjs,ts}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": "prettier --write",
    "*.{yaml,yml}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2",
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "3.0.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-yml": "3.6.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.1",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0",
    "yaml-eslint-parser": "2.1.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-jsx-a11y>eslint": "10"
      }
    }
  }
}
